{
  "name": "kafka-mcp",
  "version": "1.1.2",
  "description": "MCP Server for Apache Kafka",
  "author": {
    "name": "Hajun Lee",
    "email": "wklee610@gmail.com"
  },
  "repository": "https://github.com/wklee610/kafka-mcp",
  "license": "Apache-2.0",
  "keywords": ["kafka", "apache-kafka", "mcp", "streaming", "infrastructure"],
  "mcpServers": {
    "kafka": {
      "command": "uv",
      "args": ["run", "kafka-mcp"],
      "env": {
        "KAFKA_BOOTSTRAP_SERVERS": "${KAFKA_BOOTSTRAP_SERVERS:-localhost:9092}",
        "KAFKA_CLIENT_ID": "${KAFKA_CLIENT_ID:-kafka-mcp}"
      }
    }
  }
}